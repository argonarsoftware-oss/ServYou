<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ServYou" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/brown_primary</item>
        <item name="colorPrimaryDark">@color/brown_primary_dark</item>
        <item name="colorAccent">@color/gold</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/gold</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/off_white</item>
        <item name="android:statusBarColor">@color/brown_primary_dark</item>
        <item name="android:navigationBarColor">@color/brown_primary_dark</item>
        <item name="android:windowBackground">@color/off_white</item>
    </style>

    <style name="ServYou.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/brown_primary</item>
        <item name="hintTextColor">@color/brown_primary</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <style name="ServYou.Button" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/brown_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <style name="ServYou.Button.Gold" parent="ServYou.Button">
        <item name="backgroundTint">@color/gold</item>
    </style>

    <style name="ServYou.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/card_bg</item>
    </style>
</resources>
